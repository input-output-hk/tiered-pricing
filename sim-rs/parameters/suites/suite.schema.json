{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Suite",
  "description": "A config-driven suite of sim-cli experiment jobs.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "defaults": {
      "$ref": "#/definitions/RunDefaults"
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Job"
      }
    }
  },
  "required": ["jobs"],
  "definitions": {
    "PathList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "TraceNodeList": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "SeedList": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "RunDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topology": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/definitions/PathList"
        },
        "slots": {
          "type": "integer",
          "minimum": 0
        },
        "timescale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "trace": {
          "type": "boolean"
        },
        "trace-nodes": {
          "$ref": "#/definitions/TraceNodeList"
        },
        "aggregate-events": {
          "type": "boolean"
        },
        "conformance-events": {
          "type": "boolean"
        },
        "output-root": {
          "type": "string"
        }
      }
    },
    "Job": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "label": {
          "type": "string"
        },
        "topology": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/definitions/PathList"
        },
        "compare-parameters": {
          "$ref": "#/definitions/PathList"
        },
        "slots": {
          "type": "integer",
          "minimum": 0
        },
        "timescale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "trace": {
          "type": "boolean"
        },
        "trace-nodes": {
          "$ref": "#/definitions/TraceNodeList"
        },
        "aggregate-events": {
          "type": "boolean"
        },
        "conformance-events": {
          "type": "boolean"
        },
        "seeds": {
          "$ref": "#/definitions/SeedList"
        }
      },
      "required": ["id"]
    }
  }
}
